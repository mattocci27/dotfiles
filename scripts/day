#!/bin/bash

# Date setup (Assuming macOS with coreutils/gdate)
today=$(date +"%Y-%m-%d")
tomorrow=$(gdate -d "tomorrow" '+%Y-%m-%d')
yesterday=$(gdate -d "yesterday" '+%Y-%m-%d')

# Path setup
note_dir="$SECOND_BRAIN/7-Daily Notes"
file="$note_dir/$today.md"

# Create directory if it doesn't exist (safety check)
mkdir -p "$note_dir"

cd "$SECOND_BRAIN" || exit

# Function to generate the template
new_note() {
  touch "$file"

  # Writing the template to the file
  cat <<EOF >"$file"
# $today

[[$yesterday]] - [[$tomorrow]]

## 🛠 Check
- [ ] Workout
- [ ] Paper / Study

## 🥃 Eat / Drink
- 

## 📝 Work & Log
EOF
}

# --- Main Logic ---

# Only execute creation logic if the file does NOT exist
if [ ! -f "$file" ]; then
  echo "Creating new daily note: $file"
  new_note
fi

# Open nvim (This runs regardless of whether the file is new or old)
# G: Go to end of file
# zz: Center screen
# o: Open new line below and enter Insert mode
echo "Opening note: $file"
# Replace the wrapper shell with nvim so its child --embed process exits with the UI.
exec nvim '+normal Gzzo' "$file" -c :NoNeckPain
